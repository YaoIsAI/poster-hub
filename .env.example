# PosterHub 环境变量配置
# 复制为 .env 使用: cp .env.example .env

# =========================================
# 核心配置（至少选一个）
# =========================================

# GitHub API Token
# 用于获取 GitHub 项目的 stars、topics、README 等信息
# 无 Token 也能用，但有 60次/小时 限制
# 获取地址: https://github.com/settings/tokens
GITHUB_TOKEN=

# LLM API Key（用于 AI 分析项目内容）
# 支持任意 OpenAI 兼容格式的 API
# 支持: OpenAI / DeepSeek / Claude (via API) / Qwen / MiniMax / 硅基流动 等
# 获取地址（以 DeepSeek 为例）: https://platform.deepseek.com
LLM_API_KEY=

# LLM Base URL（OpenAI 兼容格式，非必填有默认值）
# DeepSeek: https://api.deepseek.com
# OpenAI: https://api.openai.com
# 硅基流动: https://api.siliconflow.cn/v1
# MiniMax: https://api.minimaxi.com/v1
LLM_BASE_URL=

# LLM 模型名称（非必填有默认值）
# DeepSeek: deepseek-chat
# OpenAI: gpt-4o-mini
# MiniMax: MiniMax-M2.1
LLM_MODEL=

# =========================================
# 可选配置
# =========================================

# 服务端口（默认 3008）
PORT=3008

# 自定义 logo 图片路径（显示在海报底部）
# POSTER_LOGO_PATH=/path/to/logo.png

# 自定义品牌名称（显示在海报底部）
# POSTER_BRAND_NAME=YourBrand

# 本地项目根目录（默认 .. 即项目父目录）
# PROJECTS_ROOT=/path/to/projects
