/**
 * 通用海报生成器
 * 
 * 核心思路：用 LLM 生成任意类型的海报 HTML/CSS
 * 支持：文字描述 / 图片 / URL / 模板
 * 风格：微信风格 / 小红书风格 / 演出海报 / 企业宣传 等
 */

require('dotenv').config();
const https = require('https');
const { spawnSync } = require('child_process');
const httpsGet = (url) => new Promise((resolve, reject) => {
  https.get(url, { headers: { 'User-Agent': 'PosterHub/1.0' }, timeout: 15000 }, res => {
    if (res.statusCode !== 200) { reject(new Error(res.statusCode)); return; }
    let d = ''; res.on('data', c => d += c); res.on('end', () => resolve(d));
  }).on('error', reject).on('timeout', () => reject(new Error('超时')));
});

async function postJsonWithCurlFallback({ endpoint, apiKey, payload, timeoutMs = 30000 }) {
  try {
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${apiKey}`,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(payload)
    });
    const text = await response.text();
    if (!response.ok) return { ok: false, error: `HTTP ${response.status}: ${text.slice(0, 200)}` };
    return { ok: true, data: JSON.parse(text), transport: 'fetch' };
  } catch (e) {
    const args = [
      '-sS',
      '-m', String(Math.ceil(timeoutMs / 1000)),
      '-X', 'POST',
      endpoint,
      '-H', `Authorization: Bearer ${apiKey}`,
      '-H', 'Content-Type: application/json',
      '-d', '@-'
    ];
    const cp = spawnSync('curl', args, {
      input: JSON.stringify(payload),
      encoding: 'utf8',
      maxBuffer: 8 * 1024 * 1024
    });
    if (cp.status !== 0) {
      const stderr = (cp.stderr || cp.error?.message || '').trim();
      return { ok: false, error: `fetch/curl 均失败: ${stderr || e.message}` };
    }
    try {
      return { ok: true, data: JSON.parse(cp.stdout), transport: 'curl' };
    } catch (parseErr) {
      return { ok: false, error: `curl 返回非 JSON: ${(cp.stdout || '').slice(0, 160)}` };
    }
  }
}

function extractAndParseJsonFromLLM(content) {
  let raw = String(content || '').trim();
  
  // 策略：MiniMax 的 thinking 没有 <think> 标签，JSON 在 ```json code block 中。
  // 关键：找到第一个 {"title": 模式，它一定是 JSON 的起点。
  // 思路：先找最后一个 ``` 之后（code block 内容），然后在其中找 {"title": 的 { 开始。
  
  // 移除开头可能的 ```json
  raw = raw.replace(/```json\s*/i, '');
  raw = raw.replace(/```\s*/i, '');
  
  // 取最后一个 ``` 之后的内容（thinking + JSON）
  const lastTick = raw.lastIndexOf('```');
  let jsonRegion = lastTick >= 0 ? raw.substring(lastTick + 3) : raw;
  jsonRegion = jsonRegion.trim();
  
  // 在 jsonRegion 中找 {"title": 或 "title": 之前的 {
  // 思路：找第一个出现在 { ... "title": 模式的 {
  let jsonStart = -1;
  // 先找 "title": 第一次出现
  const titleIdx = jsonRegion.indexOf('"title":');
  if (titleIdx > 0) {
    // 在 "title": 之前找 {（可能中间有空白和换行）
    for (let i = titleIdx - 1; i >= 0; i--) {
      const c = jsonRegion[i];
      if (c === '{') {
        jsonStart = i;
        break;
      }
      if (c !== ' ' && c !== '\t' && c !== '\n' && c !== '\r') {
        // 不是空白，跳过这个 {
        break;
      }
    }
  }
  
  // 如果找不到 {"title":，直接找第一个独立成行的 {
  if (jsonStart < 0) {
    for (let i = 0; i < jsonRegion.length; i++) {
      if (jsonRegion[i] === '{') {
        let lineStart = jsonRegion.lastIndexOf('\n', i) + 1;
        let j = lineStart;
        while (j < i && (jsonRegion[j] === ' ' || jsonRegion[j] === '\t')) j++;
        if (j === i) { jsonStart = i; break; }
      }
    }
  }
  
  // 如果还是找不到，直接找第一个 {
  if (jsonStart < 0) {
    jsonStart = jsonRegion.indexOf('{');
  }
  
  if (jsonStart < 0) {
    throw new Error('LLM 返回格式无效（找不到 JSON）');
  }
  
  let jsonStr = jsonRegion.substring(jsonStart);
  
  // 用 brace matching 提取完整 JSON
  let braceCount = 0;
  let inString = false;
  let escaped = false;
  let complete = '';
  
  for (let i = 0; i < jsonStr.length; i++) {
    const c = jsonStr[i];
    if (escaped) { escaped = false; complete += c; continue; }
    if (c === '\\') { escaped = true; complete += c; continue; }
    if (c === '"') { inString = !inString; complete += c; continue; }
    if (inString) { complete += c; continue; }
    
    complete += c;
    if (c === '{') braceCount++;
    else if (c === '}') {
      braceCount--;
      if (braceCount === 0) break;
    }
  }
  
  jsonStr = complete;

  const attempts = [];
  attempts.push(jsonStr);
  attempts.push(
    jsonStr
      .replace(/```json/gi, '')
      .replace(/```/g, '')
      .replace(/\u201c|\u201d/g, '"')
      .replace(/\u2018|\u2019/g, "'")
      .replace(/,\s*([}\]])/g, '$1')
      .replace(/^\s*\/\/.*$/gm, '')
      .replace(/\/\*[\s\S]*?\*\//g, '')
  );
  attempts.push(
    attempts[1]
      .replace(/([{,]\s*)'([^']+?)'\s*:/g, '$1"$2":')
      .replace(/:\s*'([^']*?)'(\s*[,}\]])/g, ':"$1"$2')
  );

  let lastErr = null;
  for (const s of attempts) {
    try { return JSON.parse(s); } catch (e) { lastErr = e; }
  }

  // 最后尝试
  const simpleStart = jsonStr.indexOf('{');
  const simpleEnd = jsonStr.lastIndexOf('}');
  if (simpleStart >= 0 && simpleEnd > simpleStart) {
    const fallback = jsonStr.substring(simpleStart, simpleEnd + 1);
    try { return JSON.parse(fallback); } catch (e) { /* ignore */ }
  }

  throw lastErr || new Error('JSON 解析失败');
}

function extractHtmlFromLLMContent(rawContent) {
  let content = String(rawContent || '');
  
  // 移除 LLM thinking 内容（MiniMax 模型的思考过程）
  // 格式：<think>...</think> 或 【思考】...【/思考】
  content = content.replace(/<thinking>[\s\S]*?<\/thinking>/gi, '');
  content = content.replace(/<think>[\s\S]*?</think>/g, '');
  content = content.replace(/【思考】[\s\S]*?【\/思考】/g, '');
  content = content.replace(/^\s*\[Think\][\s\S]*?\n/m, '');
  
  const htmlStart = content.indexOf('<');
  const htmlEnd = content.lastIndexOf('>') + 1;
  if (htmlStart < 0 || htmlEnd <= htmlStart) {
    throw new Error('LLM 返回无效 HTML');
  }
  return content.substring(htmlStart, htmlEnd);
}

function normalizeText(s) {
  return String(s || '').toLowerCase().replace(/\s+/g, '').replace(/[^\w\u4e00-\u9fa5]+/g, '');
}

function auditHtmlWithPlan(html, plan, width, height) {
  const issues = [];
  const title = (plan && plan.title) || '';
  const subtitle = (plan && plan.subtitle) || '';
  const sections = Array.isArray(plan && plan.sections) ? plan.sections : [];
  const heroTitle = /class="hero-title[^>]*>([^<]+)</i.exec(html);
  const heroSubtitle = /class="hero-subtitle[^>]*>([^<]+)</i.exec(html);
  const cardNames = [...html.matchAll(/class="card-name[^>]*>([^<]+)</gi)].map(m => (m[1] || '').trim());
  const sectionTitles = [...html.matchAll(/class="section-title[^>]*>([^<]+)</gi)].map(m => (m[1] || '').trim());

  if (!heroTitle) issues.push('缺少 hero-title');
  if (!heroSubtitle) issues.push('缺少 hero-subtitle');
  if (!/class="poster"/i.test(html)) issues.push('缺少 .poster 容器');
  if (!/class="grid"/i.test(html)) issues.push('缺少 .grid 容器');
  if (!cardNames.length) issues.push('缺少卡片内容');

  if (title) {
    const actual = normalizeText(heroTitle ? heroTitle[1] : '');
    const expected = normalizeText(title);
    if (expected && !actual.includes(expected.slice(0, Math.max(2, Math.min(8, expected.length))))) {
      issues.push('主标题与规划不一致');
    }
  }
  if (subtitle) {
    const actual = normalizeText(heroSubtitle ? heroSubtitle[1] : '');
    const expected = normalizeText(subtitle);
    if (expected && actual && !actual.includes(expected.slice(0, Math.max(2, Math.min(8, expected.length))))) {
      issues.push('副标题与规划不一致');
    }
  }

  if (sections.length) {
    let sectionHit = 0;
    for (const sec of sections.slice(0, 4)) {
      const label = normalizeText(sec.label || '');
      if (!label) continue;
      if (sectionTitles.some(t => normalizeText(t).includes(label.slice(0, Math.max(2, Math.min(6, label.length)))))) {
        sectionHit += 1;
      }
    }
    if (sectionHit < Math.max(1, Math.floor(sections.length * 0.5))) {
      issues.push('分区标题与规划不一致');
    }
  }

  const plannedItems = sections.flatMap(s => Array.isArray(s.items) ? s.items : []).map(it => (it && it.title) || '').filter(Boolean);
  if (plannedItems.length) {
    let hit = 0;
    for (const p of plannedItems.slice(0, 8)) {
      const target = normalizeText(p);
      if (!target) continue;
      if (cardNames.some(n => normalizeText(n).includes(target.slice(0, Math.max(2, Math.min(6, target.length)))))) hit += 1;
    }
    if (hit < Math.max(1, Math.floor(Math.min(8, plannedItems.length) * 0.35))) {
      issues.push('卡片条目与规划不一致');
    }
  }

  if (width && !html.includes(`${width}px`)) {
    issues.push('宽度约束未显式出现');
  }
  if (height && !html.includes(`${height}px`)) {
    issues.push('高度约束未显式出现');
  }

  return { passed: issues.length === 0, issues };
}

/**
 * Harness 质量检查：HTML 结构完整性验证
 * - 检查标签是否正确闭合
 * - 检查是否有乱码
 * - 检查内容长度是否合理
 * - 检查样式是否存在
 */
function validatePosterStructure(html) {
  const issues = [];
  if (!html || typeof html !== 'string') {
    return { valid: false, issues: ['HTML 为空或无效'] };
  }

  // 1. 乱码检测：检测连续无意义字符
  const garbledPattern = /[\u4e00-\u9fa5]{10,}/g;
  const chineseChars = (html.match(/[\u4e00-\u9fa5]/g) || []).length;
  const alphaChars = (html.match(/[a-zA-Z]/g) || []).length;
  const digitChars = (html.match(/[0-9]/g) || []).length;
  const totalChars = chineseChars + alphaChars + digitChars;
  // 如果内容中有意义字符占比低于 60%，可能是乱码
  if (totalChars > 100 && totalChars / html.length < 0.4) {
    issues.push('检测到乱码或无意义内容');
  }

  // 2. 内容长度检查
  if (html.length < 500) {
    issues.push(`HTML 内容过短 (${html.length} 字符)，可能生成不完整`);
  }
  if (html.length > 200000) {
    issues.push(`HTML 内容过长 (${Math.round(html.length/1000)}K)，可能包含异常`);
  }

  // 3. 标签完整性检查
  const tagPairs = [
    ['<html', '</html>'],
    ['<head>', '</head>'],
    ['<body>', '</body>'],
    ['<style>', '</style>'],
  ];
  for (const [open, close] of tagPairs) {
    const hasOpen = html.includes(open);
    const hasClose = html.includes(close);
    if (hasOpen && !hasClose) {
      issues.push(`标签未闭合: ${open}`);
    }
  }

  // 4. 样式存在检查
  if (!html.includes('<style') && !html.includes('class=')) {
    issues.push('缺少样式定义');
  }

  // 5. 关键元素存在检查
  const essentialElements = [
    ['.poster', '海报容器'],
    ['class="hero', '英雄区'],
  ];
  for (const [selector, name] of essentialElements) {
    if (!html.includes(selector)) {
      issues.push(`缺少关键元素: ${name}`);
    }
  }

  return {
    valid: issues.length === 0,
    issues,
    stats: {
      length: html.length,
      chineseChars,
      alphaChars,
      digitChars
    }
  };
}

/**
 * POST /api/prompt
 * 
 * 通用海报生成接口
 * Body: {
 *   prompt: "生成一张微信风格的推广海报，内容是...",
 *   type: "wechat" | "xiaohongshu" | "performance" | "corporate" | "custom",
 *   image?: "url or base64",  // 可选的背景图片
 *   lang?: "zh" | "en",
 *   width?: 780,
 *   height?: number,      // 可选固定高度，配合不同平台比例
 *   customCss?: "自定义 CSS"  // 可选的自定义样式
 * }
 */
async function generateFromPrompt({ prompt, type = 'custom', image, lang = 'zh', width = 780, height, customCss, onStage }) {
  const mark = typeof onStage === 'function' ? onStage : () => {};
  const LLM_API_KEY = process.env.LLM_API_KEY || process.env.OPENAI_API_KEY || '';
  const LLM_BASE_URL = process.env.LLM_BASE_URL || 'https://api.minimaxi.com/v1';
  const LLM_MODEL = process.env.LLM_MODEL || 'MiniMax-M2.1';
  
  // 风格指南
  const styleGuides = {
    wechat: {
      name: '微信文章卡片',
      desc: '微信公号推文风格，白色背景，红色标题，灰色正文，简洁大方，适合朋友圈传播',
      colors: { bg: '#FFFFFF', primary: '#D34F4F', text: '#333333', secondary: '#888888', accent: '#1AAD19' },
      font: "'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      layout: '居中布局，标题突出，卡片式内容块',
      size: '推荐尺寸 900×1200px（3:4比例，适合朋友圈传播）',
    },
    xiaohongshu: {
      name: '小红书风格',
      desc: '小红书笔记风格，粉色/橙色渐变，卡片圆润，大emoji，年轻人风格',
      colors: { bg: '#FEF2F2', primary: '#FF6B6B', text: '#2D3436', secondary: '#636E72', accent: '#FF9F43', gradient: 'linear-gradient(135deg, #FF6B6B 0%, #FF9F43 100%)' },
      font: "'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      layout: '左图右文或上图下文，圆角卡片，阴影柔和',
      size: '推荐尺寸 1080×1440px（3:4竖版比例，适合小红书笔记）',
    },
    performance: {
      name: '演唱会/演出海报',
      desc: '演唱会海报风格，深色背景，霓虹渐变，大标题高对比，适合活动宣传',
      colors: { bg: '#0D0D0D', primary: '#FFFFFF', text: '#E0E0E0', secondary: '#888888', accent: '#FF2D55', gradient: 'linear-gradient(180deg, #667eea 0%, #764ba2 100%)' },
      font: "'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      layout: '全屏沉浸式，大标题居中，时间地点突出，底部CTA按钮',
      size: '推荐尺寸 1080×1920px（9:16竖版比例，适合手机全屏展示）',
    },
    corporate: {
      name: '企业宣传海报',
      desc: '企业级专业风格，蓝色主调，白色背景，结构清晰，适合B端展示',
      colors: { bg: '#FFFFFF', primary: '#0052D9', text: '#1D2129', secondary: '#86909C', accent: '#0C66E4', divider: '#E5E6EB' },
      font: "'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif",
      layout: '网格布局，数据突出，卡片分组，层次分明',
      size: '推荐尺寸 1920×1080px（16:9横版比例，适合企业展示）',
    },
    tech: {
      name: '技术项目海报',
      desc: '技术项目介绍风格，简洁专业，代码感，适合技术社区分享',
      colors: { bg: '#FFFFFF', primary: '#1D1D1F', text: '#333333', secondary: '#888888', accent: '#007AFF' },
      font: "'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', -apple-system, sans-serif",
      layout: '居中布局，标题突出，代码块风格',
      size: '推荐尺寸 780px 宽度（自适应高度）',
    },
    custom: {
      name: '自定义风格',
      desc: '根据你的描述生成最合适的海报',
      colors: { bg: '#FFFFFF', primary: '#1D1D1F', text: '#333333', secondary: '#888888', accent: '#007AFF' },
      font: "'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', -apple-system, sans-serif",
      layout: '自由布局',
      size: '尺寸根据内容自由决定',
    }
  };

  const style = styleGuides[type] || styleGuides.custom;
  
  // 构建 LLM prompt
  const llmPrompt = `你是一个专业的海报设计师。请根据用户的描述生成一张高质量的 HTML/CSS 海报。

【海报要求】
"${prompt}"

【风格】${style.name}
${style.desc}
${style.size ? '【推荐尺寸】' + style.size : ''}

【布局】${style.layout}

【技术约束】
- 海报宽度: ${width}px（固定）
- 高度: ${height ? `${height}px（固定）` : '根据内容自适应（不是固定值）'}
- 语言: ${lang === 'zh' ? '中文（主要）' : '英文（主要）'}
- 字体: ${style.font}

【颜色系统】
背景色: ${style.colors.bg}
主标题色: ${style.colors.primary}
正文色: ${style.colors.text}
辅助色: ${style.colors.secondary}
强调色: ${style.colors.accent}
${style.colors.gradient ? '渐变: ' + style.colors.gradient : ''}

【自适应 CSS 规则（必须遵循）】
1. 响应式标题: .hero-title { font-size: clamp(32px, 8vw, 72px); font-weight: 800; }
2. flex 换行: .grid { display: flex; flex-wrap: wrap; gap: 20px; }
3. flex 子项: .card { flex: 1 1 calc(50% - 10px); min-width: 0; max-width: 100%; box-sizing: border-box; }
4. 文本溢出: .card-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100%; min-width: 0; }
   或者让长标题自然换行（推荐）
5. card-top flex 容器: .card-top { display: flex; align-items: center; gap: 12px; min-width: 0; }
6. card-name 在 flex 中: .card-name { flex: 1; min-width: 0; }

【图片处理】
${image ? '用户提供了背景图片，使用 <img src="' + image + '"> 嵌入' : '无背景图片，使用纯色或渐变背景'}

【自定义 CSS（可选）】
${customCss ? '用户额外要求：\n' + customCss : '无'}

【HTML 结构示例】
<div class="poster">
  <div class="hero">
    <div class="hero-badge">标签</div>
    <div class="hero-title">主标题</div>
    <div class="hero-subtitle">副标题/描述</div>
    <div class="hero-stats">统计数字</div>
  </div>
  <div class="content">
    <div class="section">
      <div class="section-title">模块标题</div>
      <div class="grid">
        <div class="card">
          <div class="card-body">
            <div class="card-emoji">🎯</div>
            <div class="card-name">功能名称</div>
            <div class="card-desc">功能描述...</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="footer">
    <div class="footer-cta">底部行动号召</div>
    <div class="footer-brand">品牌/来源</div>
  </div>
</div>

请生成完整的 HTML 代码（包含 <style>），只返回 HTML，不要有 markdown 格式，不要有解释。`;

  if (!LLM_API_KEY) {
    throw new Error('未配置 LLM_API_KEY，请先配置');
  }

  try {
  // 检测是否为本地 Ollama（原生 API vs OpenAI 兼容）
  const isOllama = LLM_BASE_URL.includes(':11434');
  const endpoint = isOllama 
    ? `${LLM_BASE_URL.replace('/v1', '')}/api/chat`  // 原生: /api/chat
    : `${LLM_BASE_URL}/chat/completions`;  // OpenAI 兼容: /v1/chat/completions
  
  const callLlm = async (userPrompt, opts = {}) => {
    const jsonMode = !!opts.jsonMode;
    const payload = isOllama
      ? {
          model: LLM_MODEL,
          messages: [{ role: 'user', content: userPrompt }],
          stream: false,
          format: jsonMode ? 'json' : undefined,
          options: {
            temperature: opts.temperature ?? 0.4,
            num_predict: opts.maxTokens ?? 8000
          }
        }
      : {
          model: LLM_MODEL,
          messages: [{ role: 'user', content: userPrompt }],
          max_tokens: opts.maxTokens ?? 8000,
          temperature: opts.temperature ?? 0.4,
          response_format: jsonMode ? { type: 'json_object' } : undefined
        };
    const call = await postJsonWithCurlFallback({
      endpoint,
      apiKey: LLM_API_KEY,
      payload,
      timeoutMs: opts.timeoutMs || 120000
    });
    if (!call.ok) throw new Error(`LLM API error: ${call.error}`);
    const data = call.data || {};
    return data.choices?.[0]?.message?.content || data.message?.content || data.message?.thinking || data.response || '';
  };

  // 1) 规划器：先生成结构化计划
  const planPrompt = `请根据海报需求输出严格 JSON 规划（只返回 JSON）：
{
  "title": "主标题",
  "subtitle": "副标题",
  "sections": [{"label":"分区名","items":[{"title":"卡片标题","desc":"卡片描述"}]}],
  "cta": "底部行动语"
}

需求：${prompt}
风格：${style.name}
语言：${lang}
限制：sections <= 4，每个 section 的 items <= 6。`;
  mark('planning_content');
  const planText = await callLlm(planPrompt, { jsonMode: true, temperature: 0.2, maxTokens: 1800, timeoutMs: 60000 });
  
  // 检查 LLM 返回是否有效
  if (!planText || planText.length < 10 || planText.trim() === '...') {
    throw new Error('LLM 返回内容无效，请重试或切换模型');
  }
  
  let plan;
  try {
    plan = extractAndParseJsonFromLLM(planText);
  } catch(jsonErr) {
    console.error('JSON 解析失败，LLM 返回:', planText.slice(0, 200));
    throw new Error('海报生成失败: LLM 返回了无效的 JSON（' + jsonErr.message + '）');
  }

  // 2) 生成器：按计划出 HTML
  const generationPrompt = llmPrompt + `\n\n【内容规划 JSON（必须严格遵循）】\n${JSON.stringify(plan, null, 2)}`;
  mark('building_html');
  const htmlContent = await callLlm(generationPrompt, { temperature: 0.45, maxTokens: 8000, timeoutMs: 120000 });
  if (!htmlContent || htmlContent.length < 100 || htmlContent.trim() === '...') {
    throw new Error('海报生成失败: LLM 返回内容无效，请重试或切换模型');
  }
  let html;
  try {
    html = extractHtmlFromLLMContent(htmlContent);
  } catch(htmlErr) {
    console.error('HTML 提取失败，LLM 返回:', htmlContent.slice(0, 200));
    throw new Error('海报生成失败: ' + htmlErr.message);
  }

  // 3) 审查与自动纠偏闭环（最多 3 轮）
  mark('auditing_html');
  let audit = auditHtmlWithPlan(html, plan, width, height);
  let structure = validatePosterStructure(html);
  let round = 0;
  while ((!audit.passed || !structure.valid) && round < 3) {
    round += 1;
    const allIssues = [
      ...(audit.issues || []),
      ...(structure.issues || [])
    ];
    mark('repairing_html', { round, issues: allIssues.slice(0, 6) });
    const repairPrompt = `你是海报审查纠偏器。请修复 HTML 问题，使其符合要求。
只返回完整 HTML（包含 <style>），不要解释。

【规划 JSON】
${JSON.stringify(plan, null, 2)}

【当前问题】
${allIssues.map((x, i) => `${i + 1}. ${x}`).join('\n')}

【当前 HTML】
${html}`;
    html = extractHtmlFromLLMContent(await callLlm(repairPrompt, { temperature: 0.25, maxTokens: 9000, timeoutMs: 120000 }));
    mark('auditing_html', { round });
    audit = auditHtmlWithPlan(html, plan, width, height);
    structure = validatePosterStructure(html);
  }
  if (!audit.passed) {
    throw new Error('审查未通过：' + audit.issues.slice(0, 4).join('；'));
  }
  if (!structure.valid) {
    console.warn('⚠️ Harness 结构检查警告:', structure.issues.slice(0, 3));
  }

    function injectStyles(targetHtml, styles) {
      const styleText = styles.filter(Boolean).join('\n');
      if (!styleText) return targetHtml;
      if (targetHtml.includes('</head>')) {
        return targetHtml.replace('</head>', styleText + '</head>');
      }
      if (targetHtml.includes('<head>')) {
        return targetHtml.replace('<head>', '<head>' + styleText);
      }
      if (targetHtml.includes('<html')) {
        return targetHtml.replace(/<html[^>]*>/i, m => m + '<head>' + styleText + '</head>');
      }
      return styleText + targetHtml;
    }
    
    // 注入响应式 CSS（确保自适应规则生效）
    const responsiveCSS = `
<style>
.hero-title { font-size: clamp(32px, 8vw, 72px) !important; word-break: break-word; }
.card-name { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 100%; min-width: 0; }
.card-top { display: flex; align-items: center; gap: 12px; min-width: 0; }
.card { flex: 1 1 calc(50% - 10px); min-width: 0; max-width: 100%; box-sizing: border-box; }
.grid { display: flex; flex-wrap: wrap; gap: 20px; }
</style>`;
    
    let frameCSS = '';
    if (height) {
      frameCSS = `
<style>
.poster {
  width: ${width}px !important;
  max-width: ${width}px !important;
  height: ${height}px !important;
  min-height: ${height}px !important;
  box-sizing: border-box;
  overflow: hidden;
  margin: 0 auto;
}
</style>`;
    }
    
    html = injectStyles(html, [responsiveCSS, frameCSS]);
    
    return { html, style: style.name, plan, audit };
    
  } catch (e) {
    throw new Error(`海报生成失败: ${e.message}`);
  }
}

/**
 * 获取支持的海报类型
 */
function getPosterTypes() {
  return [
    { id: 'wechat', name: '微信风格', desc: '微信公号推文风格，简洁大方，适合朋友圈传播' },
    { id: 'xiaohongshu', name: '小红书风格', desc: '小红书笔记风格，粉色渐变，圆角卡片，年轻人风格' },
    { id: 'performance', name: '演出海报', desc: '演唱会/活动海报，深色背景，霓虹渐变，大标题' },
    { id: 'corporate', name: '企业宣传', desc: '企业级专业风格，蓝色主调，适合B端展示' },
    { id: 'custom', name: '自定义风格', desc: '根据你的描述生成最合适的海报' },
  ];
}

module.exports = { generateFromPrompt, getPosterTypes, validatePosterStructure };
